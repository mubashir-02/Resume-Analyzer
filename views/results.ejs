<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Your AI-powered resume analysis results showing skill matches and job recommendations.">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="results-page">

  <!-- Animated background -->
  <div class="bg-gradient"></div>

  <div class="container">
    <!-- Header -->
    <header class="results-header">
      <a href="/" class="logo">
        <div class="logo-icon">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none">
            <rect width="40" height="40" rx="12" fill="url(#logoGrad2)"/>
            <path d="M12 28V18L20 12L28 18V28H23V22H17V28H12Z" fill="white" fill-opacity="0.95"/>
            <defs>
              <linearGradient id="logoGrad2" x1="0" y1="0" x2="40" y2="40">
                <stop stop-color="#6366f1"/>
                <stop offset="1" stop-color="#a855f7"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <span class="logo-text">GROW<span class="logo-dot">.AI</span></span>
      </a>
      <a href="/" class="btn-new-scan" id="btn-new-scan">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        New Analysis
      </a>
    </header>

    <!-- Profile summary -->
    <section class="profile-section">
      <div class="section-header">
        <h1>Your Resume Profile</h1>
        <div class="experience-badge badge-<%= profile.experience %>">
          <%= profile.experience.charAt(0).toUpperCase() + profile.experience.slice(1) %>
        </div>
      </div>

      <!-- Skills -->
      <div class="profile-grid">
        <div class="profile-card">
          <h3 class="card-label">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Skills Identified
          </h3>
          <div class="tag-cloud">
            <% profile.skills.forEach(skill => { %>
              <span class="tag tag-skill"><%= skill %></span>
            <% }); %>
          </div>
        </div>

        <div class="profile-card">
          <h3 class="card-label">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
              <path d="M16 7V5C16 3.9 15.1 3 14 3H10C8.9 3 8 3.9 8 5V7" stroke="currentColor" stroke-width="2"/>
            </svg>
            Suggested Roles
          </h3>
          <div class="tag-cloud">
            <% profile.roles.forEach(role => { %>
              <span class="tag tag-role"><%= role %></span>
            <% }); %>
          </div>
        </div>

        <div class="profile-card">
          <h3 class="card-label">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M4 7V4H20V7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M9 20H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 4V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Keywords
          </h3>
          <div class="tag-cloud">
            <% profile.keywords.forEach(kw => { %>
              <span class="tag tag-keyword"><%= kw %></span>
            <% }); %>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="stats-bar">
      <div class="stat-item">
        <span class="stat-value"><%= totalJobsFound %></span>
        <span class="stat-label">Jobs Found</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value"><%= filteredCount %></span>
        <span class="stat-label">Skill Matches</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value"><%= jobs.length %></span>
        <span class="stat-label">AI Scored</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value"><%= profile.skills.length %></span>
        <span class="stat-label">Skills Found</span>
      </div>
    </section>

    <!-- Job matches -->
    <section class="jobs-section">
      <h2 class="section-title">AI-Matched Jobs</h2>

      <% if (jobs.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">🔍</div>
          <h3>No Matching Jobs Found</h3>
          <p>We couldn't find strong job matches right now. Try updating your resume with more specific skills.</p>
          <a href="/" class="btn-analyze">Try Again</a>
        </div>
      <% } else { %>
        <div class="job-cards">
          <% jobs.forEach((job, index) => { %>
            <div class="job-card" style="animation-delay: <%= index * 0.06 %>s">
              <!-- Match header -->
              <div class="job-card-header">
                <div class="job-info">
                  <h3 class="job-title"><%= job.title %></h3>
                  <p class="job-company"><%= job.company %></p>
                  <% if (job.salary && job.salary !== 'Not specified') { %>
                    <p class="job-salary">💰 <%= job.salary %></p>
                  <% } %>
                </div>
                <div class="match-ring match-<%= job.match_percentage >= 70 ? 'high' : (job.match_percentage >= 40 ? 'mid' : 'low') %>">
                  <svg viewBox="0 0 80 80">
                    <circle cx="40" cy="40" r="34" fill="none" stroke="currentColor" stroke-opacity="0.1" stroke-width="6"/>
                    <circle cx="40" cy="40" r="34" fill="none" stroke="currentColor" stroke-width="6"
                      stroke-dasharray="<%= (job.match_percentage / 100) * 213.6 %> 213.6"
                      stroke-linecap="round" transform="rotate(-90 40 40)"/>
                  </svg>
                  <span class="match-value"><%= job.match_percentage %>%</span>
                </div>
              </div>

              <!-- Reason -->
              <p class="job-reason"><%= job.reason %></p>

              <!-- Skills comparison -->
              <div class="skills-comparison">
                <div class="skill-group skill-matched">
                  <h4>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                      <path d="M20 6L9 17L4 12" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Matched
                  </h4>
                  <div class="skill-tags">
                    <% job.matched_skills.forEach(s => { %>
                      <span class="mini-tag matched"><%= s %></span>
                    <% }); %>
                    <% if (job.matched_skills.length === 0) { %>
                      <span class="mini-tag none">None</span>
                    <% } %>
                  </div>
                </div>
                <div class="skill-group skill-missing">
                  <h4>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                      <path d="M18 6L6 18M6 6L18 18" stroke="#f43f5e" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                    Missing
                  </h4>
                  <div class="skill-tags">
                    <% job.missing_skills.forEach(s => { %>
                      <span class="mini-tag missing"><%= s %></span>
                    <% }); %>
                    <% if (job.missing_skills.length === 0) { %>
                      <span class="mini-tag perfect">All matched!</span>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="job-card-actions">
                <button type="button" class="btn-improve" onclick="improveResume(<%= index %>)">Improve Resume for this Job</button>
                <a href="<%= job.apply_url %>" target="_blank" rel="noopener noreferrer" class="btn-apply" id="apply-btn-<%= index %>">
                  Apply Now
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Improve resume modal -->
    <div id="improve-modal" class="improve-modal" hidden aria-hidden="true">
      <div class="improve-modal-backdrop" onclick="closeImproveModal()"></div>
      <div class="improve-modal-dialog" role="dialog" aria-labelledby="improve-modal-title">
        <div class="improve-modal-header">
          <h2 id="improve-modal-title">Improved resume for this job</h2>
          <button type="button" class="improve-modal-close" onclick="closeImproveModal()" aria-label="Close">&times;</button>
        </div>
        <p id="improve-modal-status" class="improve-modal-status"></p>
        <div id="improve-modal-summary-wrap" class="improve-summary-wrap" hidden>
          <h3 class="improve-subheading">Suggested summary</h3>
          <p id="improve-modal-summary" class="improve-summary-text"></p>
        </div>
        <div id="improve-modal-skills-wrap" class="improve-skills-wrap" hidden>
          <h3 class="improve-subheading">Skills to highlight</h3>
          <div id="improve-modal-skills" class="improve-skill-tags"></div>
        </div>
        <h3 class="improve-subheading">Experience: original vs improved</h3>
        <div id="improve-modal-rows" class="improve-rows"></div>
      </div>
    </div>

    <script type="application/json" id="improve-page-data"><%- improvePageJson %></script>
    <script>
      (function () {
        var dataEl = document.getElementById('improve-page-data');
        var ctx = { resumeText: '', jobs: [] };
        if (dataEl && dataEl.textContent) {
          try {
            ctx = JSON.parse(dataEl.textContent);
            // #region agent log
            fetch('http://127.0.0.1:7596/ingest/fcb39686-00b0-4314-b4ec-c49112998452', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Debug-Session-Id': 'b73140' },
              body: JSON.stringify({
                sessionId: 'b73140',
                runId: 'post-fix-v2',
                hypothesisId: 'H2',
                location: 'results.ejs:ctx-after-parse',
                message: 'client ctx from improve-page-data',
                data: {
                  resumeLen: (ctx.resumeText && String(ctx.resumeText).length) || 0,
                  resumeTrimLen: (ctx.resumeText && String(ctx.resumeText).trim().length) || 0,
                  jobsCount: (ctx.jobs && ctx.jobs.length) || 0,
                  jsonSnippetLen: dataEl.textContent.length
                },
                timestamp: Date.now()
              })
            }).catch(function () {});
            // #endregion
          } catch (e) {
            console.error(e);
            // #region agent log
            fetch('http://127.0.0.1:7596/ingest/fcb39686-00b0-4314-b4ec-c49112998452', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Debug-Session-Id': 'b73140' },
              body: JSON.stringify({
                sessionId: 'b73140',
                runId: 'post-fix',
                hypothesisId: 'H3',
                location: 'results.ejs:parse-error',
                message: 'JSON.parse failed for improve-page-data',
                data: { err: String(e && e.message), rawLen: dataEl.textContent.length },
                timestamp: Date.now()
              })
            }).catch(function () {});
            // #endregion
          }
        }

        window.closeImproveModal = function () {
          var modal = document.getElementById('improve-modal');
          if (!modal) return;
          modal.hidden = true;
          modal.setAttribute('aria-hidden', 'true');
        };

        function openImproveModal() {
          var modal = document.getElementById('improve-modal');
          if (!modal) return;
          modal.hidden = false;
          modal.setAttribute('aria-hidden', 'false');
        }

        function setStatus(msg) {
          var el = document.getElementById('improve-modal-status');
          if (el) el.textContent = msg || '';
        }

        function renderPayload(data) {
          var rows = document.getElementById('improve-modal-rows');
          var sumWrap = document.getElementById('improve-modal-summary-wrap');
          var sumEl = document.getElementById('improve-modal-summary');
          var skWrap = document.getElementById('improve-modal-skills-wrap');
          var skEl = document.getElementById('improve-modal-skills');
          if (!rows) return;

          rows.innerHTML = '';
          var list = data.improvements || data.bullets || [];
          if (data.summary && sumEl && sumWrap) {
            sumEl.textContent = data.summary;
            sumWrap.hidden = false;
          } else if (sumWrap) sumWrap.hidden = true;

          if (skEl && skWrap) {
            skEl.innerHTML = '';
            var skills = data.skills || [];
            if (skills.length) {
              skWrap.hidden = false;
              skills.forEach(function (s) {
                var span = document.createElement('span');
                span.className = 'improve-skill-tag';
                span.textContent = s;
                skEl.appendChild(span);
              });
            } else skWrap.hidden = true;
          }

          if (!list.length) {
            rows.innerHTML = '<p class="improve-empty">No bullet comparisons returned. Try again or check your resume formatting.</p>';
            return;
          }

          list.forEach(function (pair) {
            var row = document.createElement('div');
            row.className = 'improve-pair';
            var o = document.createElement('div');
            o.className = 'improve-col improve-col-original';
            o.innerHTML = '<span class="improve-label">Original</span><p class="improve-body"></p>';
            o.querySelector('.improve-body').textContent = pair.original || '—';

            var i = document.createElement('div');
            i.className = 'improve-col improve-col-improved';
            i.innerHTML = '<span class="improve-label">Improved</span><p class="improve-body"></p>';
            i.querySelector('.improve-body').textContent = pair.improved || '—';

            row.appendChild(o);
            row.appendChild(i);
            rows.appendChild(row);
          });
        }

        window.improveResume = async function (jobIndex) {
          var job = ctx.jobs[jobIndex];
          // #region agent log
          fetch('http://127.0.0.1:7596/ingest/fcb39686-00b0-4314-b4ec-c49112998452', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Debug-Session-Id': 'b73140' },
            body: JSON.stringify({
              sessionId: 'b73140',
              runId: 'post-fix-v2',
              hypothesisId: 'H4',
              location: 'results.ejs:improveResume-click',
              message: 'improve button clicked',
              data: {
                jobIndex: jobIndex,
                hasJob: !!job,
                resumeLen: (ctx.resumeText && String(ctx.resumeText).length) || 0,
                resumeTrimLen: (ctx.resumeText && String(ctx.resumeText).trim().length) || 0
              },
              timestamp: Date.now()
            })
          }).catch(function () {});
          // #endregion
          if (!job) {
            alert('Job not found.');
            return;
          }
          if (!ctx.resumeText || !String(ctx.resumeText).trim()) {
            alert('Resume text is not available. Upload your resume again.');
            return;
          }

          openImproveModal();
          setStatus('Improving your resume…');
          document.getElementById('improve-modal-summary-wrap').hidden = true;
          document.getElementById('improve-modal-skills-wrap').hidden = true;
          document.getElementById('improve-modal-rows').innerHTML = '';

          var jobDescription = [
            job.description,
            job.title ? 'Job title: ' + job.title : '',
            job.apply_url ? 'Apply URL: ' + job.apply_url : ''
          ].filter(Boolean).join('\n\n');

          try {
            var res = await fetch('/improve-resume', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                resumeText: ctx.resumeText,
                jobDescription: jobDescription
              })
            });
            var data = await res.json().catch(function () { return {}; });
            if (!res.ok) {
              throw new Error(data.error || data.message || 'Request failed');
            }
            setStatus('');
            renderPayload(data);
          } catch (err) {
            setStatus(err.message || 'Something went wrong.');
            document.getElementById('improve-modal-rows').innerHTML = '';
          }
        };

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') window.closeImproveModal();
        });
      })();
    </script>

    <!-- Footer -->
    <footer class="footer">
      <p>Built with ❤️ using Node.js, Gemini AI & Adzuna API</p>
      <p class="footer-sub">GROW.AI — AI Resume Analyzer</p>
    </footer>
  </div>

</body>
</html>
