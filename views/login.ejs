<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/login-page.css">
  <style>
    .dynamic-text-wrapper {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 100%;
      max-width: none;
      display: block;
      height: 30px;
      line-height: 30px;
      overflow: hidden;
      cursor: default;
    }

    .nav-ticker {
      display: inline-block;
      white-space: nowrap;
      animation: navTickerMarquee 25s linear infinite;
    }

    .nav-ticker:hover {
      animation-play-state: paused;
    }

    .nav-ticker-text {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      text-transform: uppercase;
      background: linear-gradient(90deg, #e0e7ff, #a5b4fc, #c4b5fd, #e0e7ff);
      background-size: 200% auto;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: navTextShimmer 4s linear infinite;
      display: inline-block;
      padding-right: 1.5rem;
      letter-spacing: 0.12em;
    }

    .nav-separator {
      display: inline-block;
      color: rgba(165, 180, 252, 0.3);
      font-weight: 300;
      font-size: 0.85rem;
      padding: 0 0.8rem;
      -webkit-text-fill-color: rgba(165, 180, 252, 0.3);
    }

    @keyframes navTextShimmer {
      0% { background-position: 0% center; }
      100% { background-position: 200% center; }
    }

    @keyframes navTickerMarquee {
      0% {
        transform: translateX(0%);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    @media (max-width: 768px) {
      .dynamic-text-wrapper {
        display: none;
      }
    }
  </style>
</head>

<body class="login-page">

  <div class="navbar-wrapper">
    <div class="navbar-glass">
      <nav class="navbar" aria-label="Primary" style="min-height: 50px;">
        <div id="dynamic-nav-text-container" class="dynamic-text-wrapper" title="Pause animation on hover">
            <div class="nav-ticker">
                <span class="nav-ticker-text">Turn your resume into an opportunity magnet.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Analyze. Improve. Get Hired.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Your dream job starts with a better resume.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Smart insights. Stronger resumes. Better careers.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Upgrade your resume. Unlock your future.</span><span class="nav-separator">/</span>
                <span class="nav-ticker-text">Turn your resume into an opportunity magnet.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Analyze. Improve. Get Hired.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Your dream job starts with a better resume.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Smart insights. Stronger resumes. Better careers.</span><span class="nav-separator">/</span><span class="nav-ticker-text">Upgrade your resume. Unlock your future.</span><span class="nav-separator">/</span>
            </div>
        </div>
      </nav>
    </div>
  </div>

  <section class="hero-section" aria-labelledby="landing-headline">
    <div class="hero-content">
      <h1 class="hero-headline" id="landing-headline">Grow</h1>
      <p class="hero-subtext">
        Analyze. Match. Elevate
      </p>
      <div class="hero-cta">
        <a href="/dashboard" class="cta-button">Analyze your Resume</a>
      </div>
    </div>
  </section>

  <section class="social-proof" aria-hidden="false">
    <video id="bgVideo" class="video-bg" autoplay muted playsinline>
      <source
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260308_114720_3dabeb9e-2c39-4907-b747-bc3544e2d5b7.mp4"
        type="video/mp4">
    </video>
    <div class="gradient-overlay"></div>
    <div class="social-content">
      <div class="video-spacer"></div>
      <div class="marquee-container">
        <div class="marquee-label">
          Relied on by brands<br>
          across the globe
        </div>
        <div class="marquee-wrapper">
          <div class="marquee-track" id="marqueeTrack"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var brands = ['Vortex', 'Nimbus', 'Prysma', 'Cirrus', 'Kynder', 'Halcyn'];

      function createLogoItem(name) {
        return (
          '<div class="logo-item">' +
          '<div class="logo-icon liquid-glass"><span>' + name[0] + '</span></div>' +
          '<span class="logo-name">' + name + '</span>' +
          '</div>'
        );
      }

      var marqueeTrack = document.getElementById('marqueeTrack');
      if (marqueeTrack) {
        var allBrands = brands.concat(brands);
        marqueeTrack.innerHTML = allBrands.map(createLogoItem).join('');
      }

      var video = document.getElementById('bgVideo');
      if (!video) return;

      var fadeDuration = 0.5;

      function updateVideoOpacity() {
        if (!video.duration) return;
        var currentTime = video.currentTime;
        var duration = video.duration;
        var opacity = 1;
        if (currentTime < fadeDuration) {
          opacity = currentTime / fadeDuration;
        } else if (currentTime > duration - fadeDuration) {
          var remaining = duration - currentTime;
          opacity = remaining / fadeDuration;
        }
        video.style.opacity = opacity;
      }

      function animate() {
        updateVideoOpacity();
        requestAnimationFrame(animate);
      }

      video.addEventListener('ended', function () {
        video.style.opacity = 0;
        setTimeout(function () {
          video.currentTime = 0;
          video.play();
        }, 100);
      });

      video.addEventListener('loadedmetadata', function () {
        animate();
      });

      if (video.readyState >= 2) {
        animate();
      }

    })();
  </script>
</body>

</html>