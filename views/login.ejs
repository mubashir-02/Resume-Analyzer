<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/login-page.css">
</head>
<body class="login-page">

  <div class="navbar-wrapper">
    <div class="navbar-glass">
      <nav class="navbar" aria-label="Primary">
        <a href="/login" class="logo-brand" aria-label="Grow AI home">
          <span class="logo-icon-box">
            <svg class="logo-house-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </span>
          <span class="logo-text">GROW<span class="logo-dot">.AI</span></span>
        </a>
        <div class="nav-center">
          <button type="button" class="nav-item">Features</button>
          <button type="button" class="nav-item">How it Works</button>
          <button type="button" class="nav-item">Pricing</button>
        </div>
        <a href="/dashboard" class="nav-signin-btn">Sign In</a>
      </nav>
    </div>
  </div>

  <section class="hero-section" aria-labelledby="landing-headline">
    <div class="hero-content">
      <h1 class="hero-headline" id="landing-headline">Grow</h1>
      <p class="hero-subtext">
        The most powerful AI ever deployed<br>
        in talent acquisition
      </p>
      <div class="hero-cta">
        <a href="/dashboard" class="cta-button">Analyze your Resume</a>
      </div>
    </div>
  </section>

  <section class="social-proof" aria-hidden="false">
    <video
      id="bgVideo"
      class="video-bg"
      autoplay
      muted
      playsinline
    >
      <source src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260308_114720_3dabeb9e-2c39-4907-b747-bc3544e2d5b7.mp4" type="video/mp4">
    </video>
    <div class="gradient-overlay"></div>
    <div class="social-content">
      <div class="video-spacer"></div>
      <div class="marquee-container">
        <div class="marquee-label">
          Relied on by brands<br>
          across the globe
        </div>
        <div class="marquee-wrapper">
          <div class="marquee-track" id="marqueeTrack"></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var brands = ['Vortex', 'Nimbus', 'Prysma', 'Cirrus', 'Kynder', 'Halcyn'];

      function createLogoItem(name) {
        return (
          '<div class="logo-item">' +
          '<div class="logo-icon liquid-glass"><span>' + name[0] + '</span></div>' +
          '<span class="logo-name">' + name + '</span>' +
          '</div>'
        );
      }

      var marqueeTrack = document.getElementById('marqueeTrack');
      if (marqueeTrack) {
        var allBrands = brands.concat(brands);
        marqueeTrack.innerHTML = allBrands.map(createLogoItem).join('');
      }

      var video = document.getElementById('bgVideo');
      if (!video) return;

      var fadeDuration = 0.5;

      function updateVideoOpacity() {
        if (!video.duration) return;
        var currentTime = video.currentTime;
        var duration = video.duration;
        var opacity = 1;
        if (currentTime < fadeDuration) {
          opacity = currentTime / fadeDuration;
        } else if (currentTime > duration - fadeDuration) {
          var remaining = duration - currentTime;
          opacity = remaining / fadeDuration;
        }
        video.style.opacity = opacity;
      }

      function animate() {
        updateVideoOpacity();
        requestAnimationFrame(animate);
      }

      video.addEventListener('ended', function () {
        video.style.opacity = 0;
        setTimeout(function () {
          video.currentTime = 0;
          video.play();
        }, 100);
      });

      video.addEventListener('loadedmetadata', function () {
        animate();
      });

      if (video.readyState >= 2) {
        animate();
      }
    })();
  </script>
</body>
</html>
