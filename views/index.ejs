    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('resume-input');
        const fileSelected = document.getElementById('file-selected');
        const fileName = document.getElementById('file-name');
        const fileSize = document.getElementById('file-size');
        const fileRemove = document.getElementById('file-remove');
        const btnAnalyze = document.getElementById('btn-analyze');
        const uploadForm = document.getElementById('upload-form');
        const loadingOverlay = document.getElementById('loading-overlay');

        // Click to upload
        dropZone.addEventListener('click', () => fileInput.click());

        // Drag and drop
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('drag-over');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('drag-over');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('drag-over');
            const files = e.dataTransfer.files;
            if (files.length > 0 && files[0].type === 'application/pdf') {
                fileInput.files = e.dataTransfer.files;
                showFile(files[0]);
            } else {
                showToast('Please upload a PDF file only.', 'error');
            }
        });

        // File selected
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length > 0) {
                showFile(fileInput.files[0]);
            }
        });

        function showFile(file) {
            if (file.type !== 'application/pdf') {
                showToast('Please upload a PDF file only.', 'error');
                return;
            }
            if (file.size > 10 * 1024 * 1024) {
                showToast('File size must be less than 10MB.', 'error');
                return;
            }
            fileName.textContent = file.name;
            fileSize.textContent = formatBytes(file.size);
            dropZone.style.display = 'none';
            fileSelected.classList.remove('hidden');
            btnAnalyze.disabled = false;
            lucide.createIcons();
        }

        // Remove file
        fileRemove.addEventListener('click', (e) => {
            e.stopPropagation();
            fileInput.value = '';
            dropZone.style.display = 'flex';
            fileSelected.classList.add('hidden');
            btnAnalyze.disabled = true;
        });

        // Format bytes
        function formatBytes(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        // Form submit — show loading
        uploadForm.addEventListener('submit', () => {
            loadingOverlay.classList.add('active');
            loadingOverlay.setAttribute('aria-hidden', 'false');

            const progressValue = document.getElementById('progress-value');
            const progressFill = document.getElementById('progress-fill');

            const steps = [
                { el: 'step-1', delay: 0, pct: 35, label: 'Active' },
                { el: 'step-2', delay: 3000, pct: 55, label: 'Active' },
                { el: 'step-3', delay: 8000, pct: 78, label: 'Active' },
                { el: 'step-4', delay: 14000, pct: 92, label: 'Active' }
            ];

            const allStepEls = steps.map(s => document.getElementById(s.el)).filter(Boolean);
            allStepEls.forEach((el, idx) => {
                el.classList.toggle('active', idx === 0);
                el.classList.toggle('completed', false);
                const badge = el.querySelector('.analyze-step-status');
                if (badge) badge.textContent = idx === 0 ? 'Active' : 'Pending';
            });

            if (progressValue) progressValue.textContent = '35%';
            if (progressFill) progressFill.style.width = '35%';

            steps.forEach((step, idx) => {
                setTimeout(() => {
                    allStepEls.forEach((el, j) => {
                        const isActive = j === idx;
                        const isCompleted = j < idx;
                        el.classList.toggle('active', isActive);
                        el.classList.toggle('completed', isCompleted);
                        const badge = el.querySelector('.analyze-step-status');
                        if (badge) badge.textContent = isActive ? 'Active' : (isCompleted ? 'Done' : 'Pending');
                    });

                    if (progressValue) progressValue.textContent = step.pct + '%';
                    if (progressFill) progressFill.style.width = step.pct + '%';
                }, step.delay);
            });
        });

        // Toast notification
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-6 right-6 px-6 py-3 rounded-xl glass text-sm font-medium z-[200] animate-slide-up ${type === 'success' ? 'text-sage-300' : 'text-coral-300'
                }`;
            toast.style.border = type === 'success' ? '1px solid rgba(163,181,163,0.2)' : '1px solid rgba(251,113,133,0.2)';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // Scroll reveal animation
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        // Parallax effect for orbs
        document.addEventListener('mousemove', (e) => {
            const orbs = document.querySelectorAll('.orb');
            orbs.forEach((orb, index) => {
                const speed = (index + 1) * 15;
                const xOffset = (window.innerWidth / 2 - e.clientX) / speed;
                const yOffset = (window.innerHeight / 2 - e.clientY) / speed;
                orb.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
            });
        });
    </script>
