<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="GROW.AI — Upload your resume and get AI-powered job matching with skill analysis and career recommendations.">
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700&f[]=clash-display@400,500,600,700&display=swap"
        rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Satoshi', 'sans-serif'],
                        display: ['Clash Display', 'sans-serif'],
                    },
                    colors: {
                        bg: { primary: '#0f0f0f', secondary: '#1a1a1a', tertiary: '#242424' },
                        warm: {
                            50: '#fafaf9', 100: '#f5f5f4', 200: '#e7e5e4', 300: '#d6d3d1',
                            400: '#a8a29e', 500: '#78716c', 600: '#57534e', 700: '#44403c',
                            800: '#292524', 900: '#1c1917',
                        },
                        coral: {
                            50: '#fff1f2', 100: '#ffe4e6', 200: '#fecdd3', 300: '#fda4af',
                            400: '#fb7185', 500: '#f43f5e', 600: '#e11d48',
                        },
                        sage: {
                            50: '#f6f7f6', 100: '#e3e7e3', 200: '#c7d2c7', 300: '#a3b5a3',
                            400: '#7a947a', 500: '#5c7a5c', 600: '#486148',
                        },
                        sand: {
                            50: '#fdfbf7', 100: '#f7f3e8', 200: '#efe5d0',
                            300: '#e6d5b8', 400: '#d4b896',
                        }
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'shimmer': 'shimmer 2.5s linear infinite',
                        'gradient-x': 'gradient-x 8s ease infinite',
                        'fade-in': 'fadeIn 0.6s ease-out forwards',
                        'slide-up': 'slideUp 0.8s ease-out forwards',
                    },
                    keyframes: {
                        float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-20px)' } },
                        shimmer: { '0%': { backgroundPosition: '-200% 0' }, '100%': { backgroundPosition: '200% 0' } },
                        'gradient-x': { '0%, 100%': { 'background-position': '0% 50%' }, '50%': { 'background-position': '100% 50%' } },
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        slideUp: { '0%': { opacity: '0', transform: 'translateY(30px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #0f0f0f;
            color: #fafaf9;
            font-family: 'Satoshi', sans-serif;
            overflow-x: hidden;
        }

        .noise {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 100;
            opacity: 0.025;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        .glass {
            background: rgba(26, 26, 26, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .glass-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .glass-card:hover {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
            border-color: rgba(251, 113, 133, 0.2);
            transform: translateY(-4px);
        }

        .text-gradient {
            background: linear-gradient(135deg, #fb7185 0%, #fda4af 50%, #f7f3e8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .text-gradient-alt {
            background: linear-gradient(135deg, #a3b5a3 0%, #d4b896 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .gradient-bg {
            background: linear-gradient(-45deg, #0f0f0f, #1a1a1a, #1c1917, #0f0f0f);
            background-size: 400% 400%;
            animation: gradient-x 15s ease infinite;
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.4;
            animation: float 8s ease-in-out infinite;
        }

        .orb-1 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(251, 113, 133, 0.25) 0%, transparent 70%);
            top: -10%;
            right: -10%;
            animation-delay: 0s;
        }

        .orb-2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(163, 181, 163, 0.2) 0%, transparent 70%);
            bottom: 20%;
            left: -5%;
            animation-delay: 2s;
        }

        .orb-3 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(212, 184, 150, 0.2) 0%, transparent 70%);
            top: 40%;
            right: 20%;
            animation-delay: 4s;
        }

        .upload-zone {
            background: linear-gradient(135deg, rgba(251, 113, 133, 0.05) 0%, rgba(163, 181, 163, 0.05) 100%);
            border: 2px dashed rgba(251, 113, 133, 0.3);
            transition: all 0.4s ease;
        }

        .upload-zone:hover,
        .upload-zone.drag-over {
            background: linear-gradient(135deg, rgba(251, 113, 133, 0.1) 0%, rgba(163, 181, 163, 0.1) 100%);
            border-color: rgba(251, 113, 133, 0.6);
            transform: translateY(-2px);
        }

        .btn-primary {
            background: linear-gradient(135deg, #e11d48 0%, #fb7185 100%);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .btn-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .btn-primary:hover::before {
            left: 100%;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(225, 29, 72, 0.3);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(251, 113, 133, 0.3);
        }

        .icon-wrap {
            background: linear-gradient(135deg, rgba(251, 113, 133, 0.1) 0%, rgba(163, 181, 163, 0.1) 100%);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0f0f0f;
        }

        ::-webkit-scrollbar-thumb {
            background: #292524;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #44403c;
        }

        ::selection {
            background: rgba(251, 113, 133, 0.3);
            color: #fff;
        }

        /* Loading overlay (resume analyzing) */
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 15, 15, 0.92);
            backdrop-filter: blur(16px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.35s ease;
        }

        .loading-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .analyze-bg-glow {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 800px;
            height: 800px;
            background: radial-gradient(circle,
                    rgba(255, 107, 138, 0.08) 0%,
                    transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        .analyze-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 560px;
            padding: 0 24px;
        }

        .analyze-glass-card {
            background: rgba(42, 42, 42, 0.55);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 48px 40px;
            box-shadow:
                0 20px 60px rgba(0, 0, 0, 0.4),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
            animation: analyzeCardEntry 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @keyframes analyzeCardEntry {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .analyze-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(255, 107, 138, 0.1);
            border: 1px solid rgba(255, 107, 138, 0.2);
            border-radius: 100px;
            margin-bottom: 28px;
        }

        .analyze-badge-dot {
            width: 8px;
            height: 8px;
            background: #fb7185;
            border-radius: 50%;
            animation: analyzePulse 2s ease-in-out infinite;
        }

        @keyframes analyzePulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.6;
                transform: scale(0.9);
            }
        }

        .analyze-badge-text {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #fb7185;
        }

        .analyze-title {
            font-size: 28px;
            font-weight: 700;
            color: #ffffff;
            text-align: center;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
            font-family: var(--font-display, 'Inter', sans-serif);
        }

        .analyze-subtitle {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.65);
            text-align: center;
            margin-bottom: 36px;
            font-weight: 400;
        }

        .ai-core {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto 34px;
        }

        .orbit {
            position: absolute;
            inset: 0;
            border: 2px solid transparent;
            border-top-color: #fb7185;
            border-right-color: rgba(255, 107, 138, 0.2);
            border-radius: 50%;
            animation: analyzeSpin 3s linear infinite;
        }

        .orbit-2 {
            inset: 15%;
            border-top-color: rgba(255, 107, 138, 0.6);
            animation: analyzeSpin 2s linear infinite reverse;
        }

        .orbit-3 {
            inset: 30%;
            border-top-color: rgba(255, 107, 138, 0.3);
            animation: analyzeSpin 1.5s linear infinite;
        }

        @keyframes analyzeSpin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .core-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #fb7185, #e85d75);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 32px rgba(255, 107, 138, 0.3);
        }

        .core-icon svg {
            width: 24px;
            height: 24px;
            fill: #ffffff;
        }

        .analyze-steps {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 28px;
        }

        .analyze-step {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            transition: all 0.3s ease;
        }

        .analyze-step.active {
            background: rgba(255, 107, 138, 0.08);
            border-color: rgba(255, 107, 138, 0.3);
            transform: translateX(6px);
        }

        .analyze-step.completed {
            opacity: 0.55;
        }

        .analyze-step-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.09);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .analyze-step.active .analyze-step-icon {
            background: rgba(255, 107, 138, 0.15);
            border-color: rgba(255, 107, 138, 0.4);
        }

        .analyze-step.completed .analyze-step-icon {
            background: rgba(34, 197, 94, 0.15);
            border-color: rgba(34, 197, 94, 0.3);
        }

        .analyze-step-icon svg {
            width: 18px;
            height: 18px;
            stroke: rgba(255, 255, 255, 0.65);
            stroke-width: 2;
            fill: none;
        }

        .analyze-step.active .analyze-step-icon svg {
            stroke: #ff8fa3;
        }

        .analyze-step.completed .analyze-step-icon svg {
            stroke: #22c55e;
        }

        .analyze-step-title {
            font-size: 14px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.92);
            margin-bottom: 3px;
        }

        .analyze-step-desc {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 400;
        }

        .analyze-step-status {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 6px 12px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.35);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .analyze-step.active .analyze-step-status {
            background: rgba(255, 107, 138, 0.15);
            color: #fb7185;
            border-color: rgba(255, 107, 138, 0.3);
        }

        .progress-section {
            background: rgba(0, 0, 0, 0.28);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 18px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .progress-label {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.6);
            font-weight: 500;
        }

        .progress-value {
            font-size: 20px;
            font-weight: 700;
            color: #fb7185;
        }

        .progress-bar {
            height: 6px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 100px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            width: 35%;
            background: linear-gradient(90deg, #fb7185, #ff8fa3);
            border-radius: 100px;
            animation: analyzeShimmer 2s infinite;
            background-size: 200% 100%;
        }

        @keyframes analyzeShimmer {
            0% {
                background-position: 100% 0;
            }

            100% {
                background-position: -100% 0;
            }
        }

        .time-estimate {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.35);
        }

        .time-estimate svg {
            width: 16px;
            height: 16px;
            stroke: rgba(255, 255, 255, 0.35);
            stroke-width: 2;
            fill: none;
        }

        @media (max-width: 480px) {
            .analyze-glass-card {
                padding: 36px 24px;
            }

            .analyze-title {
                font-size: 24px;
            }

            .analyze-step-status {
                display: none;
            }
        }

        @keyframes gradient-x {

            0%,
            100% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }
        }

        @keyframes fadeIn {
            0% {
                opacity: 0;
            }

            100% {
                opacity: 1;
            }
        }

        @keyframes slideUp {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }

            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .loading-step {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.85rem;
            color: #57534e;
            transition: color 0.3s;
        }

        .loading-step.active {
            color: #fafaf9;
        }

        .step-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #57534e;
            flex-shrink: 0;
            transition: all 0.3s;
        }

        .loading-step.active .step-dot {
            background: #fb7185;
            box-shadow: 0 0 8px rgba(251, 113, 133, 0.5);
            animation: pulse-icon 1.5s ease-in-out infinite;
        }

        /* Features Dropdown */
        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown-trigger {
            display: flex;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            transition: color 0.3s;
        }

        .nav-dropdown-trigger .chevron-icon {
            width: 14px;
            height: 14px;
            transition: transform 0.3s ease;
        }

        .nav-dropdown:hover .chevron-icon {
            transform: rotate(180deg);
        }

        .nav-dropdown-menu {
            position: absolute;
            top: calc(100% + 12px);
            left: 50%;
            transform: translateX(-50%) translateY(8px);
            min-width: 260px;
            background: rgba(26, 26, 26, 0.85);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 8px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.05) inset;
            z-index: 100;
        }

        .nav-dropdown:hover .nav-dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }

        .nav-dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            transition: all 0.25s ease;
            text-decoration: none;
            cursor: pointer;
        }

        .nav-dropdown-item:hover {
            background: rgba(255, 255, 255, 0.06);
        }

        .nav-dropdown-item .dd-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .nav-dropdown-item .dd-icon i {
            width: 18px;
            height: 18px;
        }

        .nav-dropdown-item .dd-label {
            font-size: 13px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 2px;
        }

        .nav-dropdown-item .dd-desc {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 400;
        }

        /* Sign In button glow */
        .signin-btn {
            position: relative;
            overflow: hidden;
            transition: all 0.35s ease;
        }

        .signin-btn:hover {
            background: rgba(251, 113, 133, 0.15) !important;
            border-color: rgba(251, 113, 133, 0.4) !important;
            color: #fb7185 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(251, 113, 133, 0.2);
        }
    </style>
</head>

<body class="gradient-bg min-h-screen relative">
    <!-- Noise overlay -->
    <div class="noise"></div>

    <!-- Ambient orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
        <div class="max-w-7xl mx-auto glass rounded-2xl px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div
                    class="w-10 h-10 rounded-xl bg-gradient-to-br from-coral-500 to-coral-600 flex items-center justify-center shadow-lg shadow-coral-500/20">
                    <i data-lucide="sparkles" class="w-5 h-5 text-white"></i>
                </div>
                <span class="font-display font-semibold text-xl tracking-tight text-warm-100">GROW<span
                        class="text-coral-400">.AI</span></span>
            </div>

            <div class="hidden md:flex items-center gap-8 text-sm font-medium text-warm-400">
                <!-- Features Dropdown -->
                <div class="nav-dropdown">
                    <a href="#features" class="nav-dropdown-trigger hover:text-warm-100 transition-colors duration-300">
                        Features
                        <svg class="chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </a>
                    <div class="nav-dropdown-menu">
                        <a href="#features" class="nav-dropdown-item">
                            <div class="dd-icon" style="background: rgba(251, 113, 133, 0.1);">
                                <i data-lucide="brain-circuit" class="text-coral-400"></i>
                            </div>
                            <div>
                                <div class="dd-label">AI Skill Extraction</div>
                                <div class="dd-desc">AI-powered skill identification</div>
                            </div>
                        </a>
                        <a href="#features" class="nav-dropdown-item">
                            <div class="dd-icon" style="background: rgba(163, 181, 163, 0.1);">
                                <i data-lucide="target" class="text-sage-400"></i>
                            </div>
